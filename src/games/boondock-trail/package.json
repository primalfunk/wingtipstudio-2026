{
  "name": "boondock-trail-ui-shell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "sim": "node tools/simulate.mjs",
    "sim:trace": "node tools/simulate.mjs trace",
    "sim:probe": "node tools/simulate.mjs batch --runs 100",
    "sim:large": "node tools/simulate.mjs batch --runs 1000",
    "sim:bulk": "node tools/sim/bulk.mjs",
    "sim:report": "node tools/simulate.mjs report",
    "tauri:dev": "powershell -ExecutionPolicy Bypass -File tools/tauri/run-tauri.ps1 dev",
    "tauri:build": "powershell -ExecutionPolicy Bypass -File tools/tauri/run-tauri.ps1 build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/manrope": "^5.2.8"
  }
}
